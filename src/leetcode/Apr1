class Solution {
    public String kthDistinct(String[] arr, int k) {
       Map<String, Integer> map = new LinkedHashMap<>();
       for(int i=0;i<arr.length;i++){
        map.put(arr[i], map.getOrDefault(arr[i],0)+1);
       }
       int x=0;
       for(var x1: map.keySet()){
          if(map.get(x1)==1){
            k--;
            if(k==0)return x1;
          }

       }
       return "";

    }
}